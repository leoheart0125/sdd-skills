{
    "entities": [
        {
            "name": "{{ EntityName }}",
            "table": "{{ table_name }}",
            "fields": [
                {
                    "name": "id",
                    "type": "UUID",
                    "primary_key": true,
                    "nullable": false
                }
            ],
            "relationships": [
                {
                    "type": "has_many",
                    "target": "{{ RelatedEntity }}",
                    "foreign_key": "{{ fk_column }}"
                }
            ]
        }
    ],
    "api_endpoints": [
        {
            "method": "GET",
            "path": "/api/{{ resource }}",
            "description": "List {{ resource }}",
            "request_params": [],
            "response_schema": "{{ EntityName }}[]",
            "auth_required": true
        }
    ],
    "openapi_ref": "openapi.yaml"
}
