{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "tasks": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "todo",
                            "in-progress",
                            "done",
                            "blocked",
                            "verified"
                        ]
                    },
                    "target_path": {
                        "type": "string",
                        "description": "Expected file path for this task's output, validated against project_rules architecture conventions"
                    },
                    "dependencies": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": [
                    "id",
                    "title",
                    "status"
                ]
            }
        }
    },
    "required": [
        "tasks"
    ]
}