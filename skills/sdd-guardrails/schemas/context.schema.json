{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "project_name": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "domain": {
            "type": "string"
        },
        "version": {
            "type": "string"
        },
        "current_stage": {
            "type": "string",
            "enum": [
                "init",
                "request",
                "request-complete",
                "design",
                "design-complete",
                "plan",
                "plan-complete",
                "impl",
                "impl-complete"
            ],
            "description": "Current lifecycle stage of the active feature"
        },
        "feature_counter": {
            "type": "string",
            "pattern": "^\\d{3}$",
            "description": "Zero-padded 3-digit counter for auto-increment feature IDs (e.g., 001, 002)"
        },
        "current_feature": {
            "oneOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Active feature name/ID currently being worked on"
        },
        "completed_features": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "History of completed feature IDs"
        },
        "active_patterns": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Pattern IDs actively applied to current work"
        },
        "applied_lessons": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Lesson IDs consulted for current work"
        }
    },
    "required": [
        "project_name",
        "current_stage"
    ]
}