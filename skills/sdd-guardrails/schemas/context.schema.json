{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "project_name": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "domain": {
            "type": "string"
        },
        "tech_stack": {
            "type": "object",
            "properties": {
                "language": {
                    "type": "string"
                },
                "framework": {
                    "type": "string"
                },
                "database": {
                    "type": "string"
                }
            },
            "required": [
                "language"
            ]
        },
        "architecture_style": {
            "type": "string"
        },
        "version": {
            "type": "string"
        }
    },
    "required": [
        "project_name",
        "tech_stack"
    ]
}