{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "architecture_style": {
            "type": "string"
        },
        "components": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    }
                },
                "required": [
                    "name",
                    "type"
                ]
            }
        },
        "data_flow": {
            "type": "array"
        },
        "decision_log": {
            "type": "array"
        }
    },
    "required": [
        "architecture_style",
        "components"
    ]
}